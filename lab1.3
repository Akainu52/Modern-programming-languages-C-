#include <iostream>

void print_state(const char* title, int a, int b) {
    std::cout << title << " a=" << a << ", b=" << b << '\n';
}

void obmen1(int a, int b) {
    int t = a;
    a = b;
    b = t;
    print_state("  inside obmen1:", a, b);
}

void obmen2(int* a, int* b) {
    int t = *a;
    *a = *b;
    *b = t;
}

void obmen3(int& a, int& b) {
    int t = a;
    a = b;
    b = t;
}

int main() {
    int a = 2;
    int b = 5;

    print_state("1) Before obmen1(int, int):", a, b);
    obmen1(a, b);
    print_state("1) After  obmen1(int, int):", a, b);
    std::cout << '\n';

    a = 2;
    b = 5;
    print_state("2) Before obmen2(int*, int*):", a, b);
    obmen2(&a, &b);
    print_state("2) After  obmen2(int*, int*):", a, b);
    std::cout << '\n';

    a = 2;
    b = 5;
    print_state("3) Before obmen3(int&, int&):", a, b);
    obmen3(a, b);
    print_state("3) After  obmen3(int&, int&):", a, b);

    return 0;
}

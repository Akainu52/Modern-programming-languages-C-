void average(float matrix[N][N], float& avr) {
    float sum = 0.0f;
    for (int i = 0; i < N; i++) {
        for (int j = 0; j < N; j++) {
            sum += matrix[i][j];
        }
    }
    avr = sum / static_cast<float>(N * N);
}

void average_down_triangle(float matrix[N][N], float& avr) {
    float sum = 0.0f;
    for (int i = 0; i < N; i++) {
        for (int j = 0; j <= i; j++) {
            sum += matrix[i][j];
        }
    }
    const int elem_count = N * (N + 1) / 2;
    avr = sum / static_cast<float>(elem_count);
}

void average_up_triangle(float matrix[N][N], float& avr) {
    float sum = 0.0f;

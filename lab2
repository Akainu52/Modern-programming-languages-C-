        }
    }
}

void nearest_to_average(float matrix[N][N], int& r, int& c) {
    float avr = 0.0f;
    average(matrix, avr);

    float best_delta = std::fabs(avr - matrix[0][0]);
    r = 0;
    c = 0;

    for (int i = 0; i < N; i++) {
        for (int j = 0; j < N; j++) {
            const float delta = std::fabs(avr - matrix[i][j]);
            if (delta < best_delta) {
                best_delta = delta;
                r = i;
                c = j;
            }
        }
    }
}

#include <iostream>

int dlina1(const char* str);
int dlina2(const char* str);
int dlina3(const char* str);
void kopir(const char* source, char* destination);
int sravn(const char* left, const char* right);
void konkat(char* destination, const char* source);

int main() {
    char str1[128] = "qwerty";
    char str2[128] = "1234567890";

    std::cout << "Length (method 1): str1=" << dlina1(str1) << ", str2=" << dlina1(str2) << '\n';
    std::cout << "Length (method 2): str1=" << dlina2(str1) << ", str2=" << dlina2(str2) << '\n';
    std::cout << "Length (method 3): str1=" << dlina3(str1) << ", str2=" << dlina3(str2) << '\n';

    kopir(str1, str2);
    std::cout << "After copy: str1=" << str1 << ", str2=" << str2 << '\n';

    const int cmp = sravn(str1, str2);
    std::cout << "Compare result: " << cmp << '\n';

    konkat(str1, str2);
    std::cout << "After concat: str1=" << str1 << ", str2=" << str2 << '\n';

    return 0;
}

int dlina1(const char* str) {
    int len = 0;
    while (str[len] != '\0') {
        ++len;
    }
    return len;
}

int dlina2(const char* str) {
    const char* p = str;
    while (*p != '\0') {
        ++p;
    }
    return static_cast<int>(p - str);
}

int dlina3(const char* str) {
    return (*str == '\0') ? 0 : 1 + dlina3(str + 1);
}


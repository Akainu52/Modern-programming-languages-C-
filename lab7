#include <conio.h>
#include <graphics.h>
#include <stdio.h>
#include <stdlib.h>
#include <time.h>

class point {
protected:
    int x;
    int y;
    int cvet;

    static int random_shift(int cost) {
        double part = (double)rand() / (double)RAND_MAX;
        return (int)((part - 0.5) * cost);
    }

public:
    point() : x(0), y(0), cvet(WHITE) {}

    virtual ~point() = default;

    virtual void init(int xn, int yn, int color) {
        x = xn;
        y = yn;
        cvet = color;
    }

    virtual void show() {}

    virtual void hide() {}

    virtual void locat(int* xl, int* yl) {
        *xl = x;
        *yl = y;
    }

    virtual void fly(int cost) {
        int xx = 0;
        int yy = 0;
        show();

        do {
            locat(&xx, &yy);
            do {
                xx = x + random_shift(cost);
            } while ((xx < 0) || (xx > getmaxx()));

            do {
                yy = y + random_shift(cost);
            } while ((yy < 0) || (yy > getmaxy()));

            hide();
            x = xx;
            y = yy;
            show();
            delay(300);
        } while (!kbhit());

        if (kbhit()) {
            getch();
        }
    }
};

class krug : public point {
protected:
    int radius;
    int sector_start;
    int sector_end;
    int base_color;

public:
    krug() : point(), radius(0), sector_start(0), sector_end(320), base_color(WHITE) {}

    void init(int xn, int yn, int r, int color) {
        point::init(xn, yn, color);
        radius = r;
        sector_start = 0;
        sector_end = 320;
        base_color = color;
        show();
    }

    void show() override {
        setcolor(cvet);
        setfillstyle(SOLID_FILL, cvet);
        pieslice(x, y, sector_start, sector_end, radius);
    }

    void hide() override {
        int bg = getbkcolor();
        setcolor(bg);
        setfillstyle(SOLID_FILL, bg);
        pieslice(x, y, sector_start, sector_end, radius);
    }

    void fly_with_color(int cost, int color2) {
        int xx = 0;
        int yy = 0;
        int current_color = base_color;

        show();
        do {
            locat(&xx, &yy);
            do {
                xx = x + random_shift(cost);
            } while ((xx < 0) || (xx > getmaxx()));

            do {
                yy = y + random_shift(cost);
            } while ((yy < 0) || (yy > getmaxy()));

            hide();
            x = xx;
            y = yy;

            if (current_color == base_color) {
                current_color = color2;
            } else {
                current_color = base_color;
            }
            cvet = current_color;

            show();
            delay(220);
        } while (!kbhit());

        if (kbhit()) {
            getch();
        }
    }

    void fly_with_sector_and_color(int cost, int color2, int sector_step, int min_end, int max_end) {
        int xx = 0;
        int yy = 0;
        int direction = -1;
        int current_color = base_color;

        show();
        do {
            locat(&xx, &yy);
            do {
                xx = x + random_shift(cost);
            } while ((xx < 0) || (xx > getmaxx()));

            do {
                yy = y + random_shift(cost);
            } while ((yy < 0) || (yy > getmaxy()));

            hide();
            x = xx;
            y = yy;

            if (current_color == base_color) {
                current_color = color2;
            } else {
                current_color = base_color;
            }
            cvet = current_color;

            sector_end += direction * sector_step;
            if (sector_end <= min_end) {
                sector_end = min_end;
                direction = 1;
            } else if (sector_end >= max_end) {
                sector_end = max_end;
                direction = -1;
            }

            show();
            delay(220);
        } while (!kbhit());

        if (kbhit()) {
            getch();
        }
    }
};

class ring : public krug {
    int width;

public:
    ring() : krug(), width(1) {}

    void cring() {}

    void init(int xn, int yn, int r, int color, int wid) {
        width = wid;
        krug::init(xn, yn, r, color);
    }

    void show() override {
        krug::show();

        int inner = radius - width;
        if (inner < 1) {
            inner = 1;
        }

        int bg = getbkcolor();
        setcolor(bg);
        setfillstyle(SOLID_FILL, bg);
        pieslice(x, y, sector_start, sector_end, inner);
    }
};

int main() {
    int d = DETECT;
    int r = 0;
    char bgipath[] = "";

    srand((unsigned)time(NULL));
    initgraph(&d, &r, bgipath);

    int errorcode = graphresult();
    if (errorcode != grOk) {
        printf("graphics error: %s\n", grapherrormsg(errorcode));
        printf("press any key to exit.\n");
        getch();
        return 1;
    }

    setbkcolor(DARKGRAY);
    cleardevice();

    krug testkrug;
    ring testring;

    testkrug.init(150, 40, 50, LIGHTBLUE);
    testring.cring();
    testring.init(450, 80, 90, LIGHTRED, 10);

    testkrug.fly(100);
    testring.fly(60);
    testkrug.fly(60);

    getch();
    testkrug.hide();
    testring.hide();
    getch();

    testkrug.fly_with_color(90, YELLOW);
    testring.fly_with_color(70, GREEN);
    getch();

    testkrug.fly_with_sector_and_color(90, YELLOW, 10, 210, 350);
    testring.fly_with_sector_and_color(70, GREEN, 8, 200, 350);
    getch();

    closegraph();
    return 0;
}
